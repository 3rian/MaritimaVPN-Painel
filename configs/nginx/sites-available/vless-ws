server {
    listen 2096 ssl http2;
    listen [::]:2096 ssl http2;
    server_name maritimavpn.shop vless.maritimavpn.shop;

    # Certificados SSL
    ssl_certificate /etc/letsencrypt/live/maritimavpn.shop/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/maritimavpn.shop/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!eNULL:!EXPORT:!DES:!MD5:!PSK:!RC4;
    ssl_prefer_server_ciphers on;

    # Banner JSON (mantido)
    location = /banner.json {
        alias /opt/maritima/banner/banner.json;
        default_type application/json;
        add_header Cache-Control "no-store";
    }

    # 🔽 FALLBACK PARA SITE REAL (QUALQUER OUTRO CAMINHO)
    location / {
        # Proxy reverso para um site comum e confiável
        proxy_pass https://cloudflare.com/;
        proxy_ssl_server_name on;
        proxy_set_header Host cloudflare.com;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Evita redirecionamentos internos indesejados
        proxy_redirect https://cloudflare.com/ /;
        proxy_redirect http://cloudflare.com/ /;

        # Timeouts padrão
        proxy_connect_timeout 30s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }

    # WebSocket do VLESS (caminho específico)
    location /mrt-7f3c9a2b {
        proxy_redirect off;
        proxy_pass http://127.0.0.1:10000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;
    }
}
